# ---- Stripe ----
# Your secret key from https://dashboard.stripe.com/apikeys
# Use the TEST key (sk_test_...) while testing, the LIVE key (sk_live_...) when going live.
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxx

# Optional but recommended: create a Product + Price in Stripe and paste its Price ID here.
# If left blank, a placeholder €25.00 price is used (see src/app/api/checkout/route.ts).
STRIPE_CLASS_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxxxx

# The public base URL of the site, used to build Stripe redirect URLs.
# Local dev: http://localhost:3000 — Production: https://mindfulmarkus.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---- Kit (ConvertKit) newsletter ----
# v3 API key from https://app.kit.com/account_settings/developer_settings
KIT_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx
# The numeric form id new subscribers are added to.
# Find it in the URL when editing a form: app.kit.com/forms/designers/1234567/edit
KIT_FORM_ID=1234567
